# Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to git (it's in .gitignore)

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-here-change-this

# API Configuration
API_RATE_LIMIT=100
MAX_TEXT_LENGTH=5000

# Model Paths (optional, defaults to backend/models/)
# MODEL_DIR=/path/to/models

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://*.vercel.app

# Logging
LOG_LEVEL=INFO

# Optional: External Model Storage
# MODEL_DOWNLOAD_URL=https://your-storage.com/models/
# GOOGLE_DRIVE_FILE_ID=your-file-id

# Optional: Database (if you add one later)
# DATABASE_URL=postgresql://user:pass@localhost/dbname

# Optional: Redis Cache (if you add one later)
# REDIS_URL=redis://localhost:6379/0

# Optional: Sentry Error Tracking
# SENTRY_DSN=your-sentry-dsn

# Optional: Analytics
# GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
